{
  "name": "featurekit",
  "version": "0.1.0",
  "description": "The dotenv of feature flags. Zero infrastructure, fully typed.",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sadatnazarli/featurekit.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/sadatnazarli/featurekit#readme",
  "bugs": {
    "url": "https://github.com/sadatnazarli/featurekit/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "feature-flags",
    "feature-toggle",
    "flags",
    "rollout",
    "ab-testing",
    "typescript"
  ],
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.0.0",
    "vitest": "^3.0.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  }
}
